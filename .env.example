# ============================================================
# MY AI Agent — 環境変数
# cp .env.example .env して値を入力してください
# .env は絶対にGitにコミットしないこと！
# ============================================================

# ── サーバー ──────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
# 本番: APP_URL=https://your-app.railway.app

# ── 必須: JWTシークレット ─────────────────────────────────────
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET

# ── 必須: Anthropic API Key ───────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── 推奨: Supabase ────────────────────────────────────────────
# https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJh...service-role-key

# ── Stripe (本番課金) ─────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Google OAuth ──────────────────────────────────────────────
# https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Authorized redirect URIs に追加: https://your-app.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxx

# ── Resend (メール送信) ───────────────────────────────────────
# https://resend.com → API Keys
# ※未設定時はコンソールにメール内容を出力（開発用）
RESEND_API_KEY=re_xxxxxx
FROM_EMAIL=noreply@myaiagent.jp

# ── 為替レート ────────────────────────────────────────────────
USD_TO_JPY=150
