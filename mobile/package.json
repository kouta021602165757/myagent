{
  "name": "myagent-mobile",
  "version": "0.1.0",
  "description": "MY AI Agent — iOS/Android (Capacitor)",
  "private": true,
  "scripts": {
    "build": "echo 'Static web assets in www/ — no build step needed'",
    "sync": "cap sync",
    "ios": "cap open ios",
    "android": "cap open android",
    "run:ios": "cap run ios",
    "run:android": "cap run android",
    "doctor": "cap doctor",
    "init:ios": "cap add ios && cap sync ios",
    "init:android": "cap add android && cap sync android",
    "icons": "node scripts/generate-icons.js",
    "splash": "node scripts/generate-splash.js",
    "screenshots": "SITE=https://myaiagents.agency node scripts/generate-screenshots.js",
    "assets:build": "npm run icons && npm run splash && npx capacitor-assets generate"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
